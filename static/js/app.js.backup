 */
function renderJobTailorResumeList() {
    renderResumeListGeneric('tailorResumeList', currentJobTailorResumeId, 'selectJobTailorResume', 'tailor-resume-card', 'No resumes yet\nUpload in Resumes section');
}

/**
 * Select a resume for job tailoring and display it
 */
function selectJobTailorResume(resumeId) {
    const resume = resumesData.find(r => r.id === resumeId);
    if (!resume) return;

    currentJobTailorResumeId = resumeId;
    currentFilename = resume.filename;

    // Update UI - highlight selected resume
    renderJobTailorResumeList();
    
    // Load and display original resume
    loadResumeContent(resumeId)
        .then(() => {
            const resume = resumesData.find(r => r.id === resumeId);
            const originalPreview = document.getElementById('tailorOriginalPreview');
            
            // Detect file type
            const fileExt = resume.filename.split('.').pop().toLowerCase();
            
            if (fileExt === 'pdf') {
                // For PDFs, show a message (or could integrate PDF viewer)
                originalPreview.innerHTML = `
                    <div style="display: flex; align-items: center; justify-content: center; height: 100%; text-align: center; color: var(--text-dim); flex-direction: column; gap: 12px;">
                        <div style="font-size: 32px;">📄</div>
                        <div>PDF Preview</div>
                        <div style="font-size: 11px;">PDF files are displayed in the Resumes panel</div>
                    </div>
                `;
            } else {
                // For TXT files, display the text
                const preElement = document.createElement('pre');
                preElement.className = 'tailor-resume-text';
                preElement.textContent = resume.content;
                originalPreview.innerHTML = '';
                originalPreview.appendChild(preElement);
            }
            
            // Reset tailored preview
            document.getElementById('tailorTailoredPreview').innerHTML = `
                <div class="tailor-placeholder">
                    <div class="tailor-placeholder-icon">🎯</div>
                    <div>Tailor Resume to see results</div>
                </div>
            `;
            document.getElementById('tailorActionButtons').style.display = 'none';
        })
        .catch(error => {
            document.getElementById('tailorOriginalPreview').innerHTML = `
                <div class="tailor-placeholder">
                    <div style="font-size: 36px; margin-bottom: 12px; color: #e74c3c;">✕</div>
                    <div style="color: #e74c3c;">Error: ${error.message}</div>
                </div>
            `;
        });
}

async function tailorResume() {
    const job = document.getElementById('jobInput').value;
    const position = document.getElementById('jobPosition').value;
    
    if (!job.trim()) {
        const tailoredPreview = document.getElementById('tailorTailoredPreview');
        tailoredPreview.innerHTML = `
            <div class="tailor-placeholder">
                <div style="font-size: 36px; margin-bottom: 12px; color: #e74c3c;">✕</div>
                <div style="color: #e74c3c;">Please enter a job description</div>
            </div>
        `;
        return;
    }

    if (!currentFilename) {
        const tailoredPreview = document.getElementById('tailorTailoredPreview');
        tailoredPreview.innerHTML = `
            <div class="tailor-placeholder">
                <div style="font-size: 36px; margin-bottom: 12px; color: #e74c3c;">✕</div>
                <div style="color: #e74c3c;">Please select a resume first</div>
            </div>
        `;
        return;
    }

    // Show loading state
    const tailoredPreview = document.getElementById('tailorTailoredPreview');
    tailoredPreview.innerHTML = `
        <div class="tailor-placeholder">
            <div style="font-size: 32px; margin-bottom: 12px; animation: spin 2s linear infinite;">⚙️</div>
            <div>Tailoring resume to job description...</div>
            <div style="font-size: 11px; color: var(--text-dim); margin-top: 8px;">This may take a moment</div>
        </div>
    `;

    try {
        const response = await fetch(`${API_BASE}/tailor-resume`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                filename: currentFilename,
                job_description: job,
                job_position: position
            })
        });

        const data = await response.json();

        if (response.ok) {
            const tailoredText = data.tailored_resume || data.resume_tailored || '';
            const preElement = document.createElement('pre');
            preElement.className = 'tailor-resume-text';
            preElement.textContent = tailoredText;
            
            tailoredPreview.innerHTML = '';
            tailoredPreview.appendChild(preElement);
            
            // Store the tailored resume content for save operations
            window.currentTailoredContent = tailoredText;
            
            // Show action buttons
            document.getElementById('tailorActionButtons').style.display = 'flex';
        } else {
            tailoredPreview.innerHTML = `
                <div class="tailor-placeholder">
                    <div style="font-size: 36px; margin-bottom: 12px; color: #e74c3c;">✕</div>
                    <div style="color: #e74c3c;">${data.error || 'Failed to tailor resume'}</div>
                </div>
            `;
            document.getElementById('tailorActionButtons').style.display = 'none';
        }
    } catch (error) {
        tailoredPreview.innerHTML = `
            <div class="tailor-placeholder">
                <div style="font-size: 36px; margin-bottom: 12px; color: #e74c3c;">✕</div>
                <div style="color: #e74c3c;">Error: ${error.message}</div>
            </div>
        `;
        document.getElementById('tailorActionButtons').style.display = 'none';
    }
}

/**
 * Replace the original resume with the tailored version
 */
async function replaceTailoredResume() {
    if (!window.currentTailoredContent || !currentFilename) {
        alert('No tailored resume to replace with');
        return;
    }

    if (!confirm('Replace the original resume? This action cannot be undone.')) {
        return;
    }

    try {
        const response = await fetch(`${API_BASE}/update-resume`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                filename: currentFilename,
                content: window.currentTailoredContent
            })
        });

        const data = await response.json();

        if (response.ok) {
            // Update the resume in memory
            const resume = resumesData.find(r => r.filename === currentFilename);
            if (resume) {
                resume.content = window.currentTailoredContent;
                saveResumesToStorage();
            }
            
            alert('✓ Original resume replaced successfully!');
        } else {
            alert(`Error: ${data.error || 'Failed to replace resume'}`);
        }
    } catch (error) {
        alert(`Error: ${error.message}`);
    }
}

/**
 * Save the tailored resume with a new name
 */
async function saveTailoredResumeAs() {
    if (!window.currentTailoredContent) {
        alert('No tailored resume to save');
        return;
    }

    const originalName = currentFilename ? currentFilename.split('.')[0] : 'resume';
    const newName = prompt('Enter a name for the tailored resume:', `${originalName}_tailored`);
    
    if (!newName || !newName.trim()) {
        return;
    }

    // Check if name already exists
    const normalizedName = newName.toLowerCase().trim();
    if (resumesData.some(r => r.filename.toLowerCase().startsWith(normalizedName))) {
        if (!confirm('A resume with this name already exists. Overwrite?')) {
            return;
        }
    }

    try {
        // Save the file
        const formData = new FormData();
        const fileContent = new Blob([window.currentTailoredContent], { type: 'text/plain' });
        const filename = `${newName}.txt`;
        formData.append('file', fileContent, filename);

        const response = await fetch(`${API_BASE}/parse-resume`, {
            method: 'POST',
            body: formData
        });

        const data = await response.json();

        if (response.ok) {
            // Reload resumes to show the new file
            await loadResumesFromFolder();
            renderJobTailorResumeList();
            
            alert(`✓ Tailored resume saved as "${data.filename}"!`);
        } else {
            alert(`Error: ${data.error || 'Failed to save resume'}`);
        }
    } catch (error) {
        alert(`Error: ${error.message}`);
    }
}

async function downloadPDF() {
    if (!currentFilename) {
        alert('No resume to download');
        return;
    }

    try {
        const response = await fetch(`${API_BASE}/generate-pdf`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ filename: currentFilename })
        });

        if (response.ok) {
            const blob = await response.blob();
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = currentFilename ? currentFilename.replace(/\.(pdf|txt)$/i, '.pdf') : 'resume.pdf';
            a.click();
            window.URL.revokeObjectURL(url);
        } else {
            alert('Failed to download PDF');
        }
    } catch (error) {
        alert(`Error: ${error.message}`);
    }
}

async function generateExperience() {
    const text = document.getElementById('experienceInput').value;
    if (!text.trim()) {
        showStatus('experienceStatus', 'Please describe your experience', 'error');
        return;
    }

    try {
        const data = await makeApiCall(
            '/update-experience',
            { description: text },
            'experienceStatus',
            (response) => {
                const bullets = response.bullets.split('\n').filter(b => b.trim());
                const list = document.getElementById('generatedBulletsList');
                list.innerHTML = bullets.map(b =>
                    `<div class="bullet-item">• ${b.replace(/^- /, '').trim()}</div>`
                ).join('');
                document.getElementById('experienceResults').style.display = 'flex';
            },
            'Generating bullets...'
        );
    } catch (error) {
        document.getElementById('experienceResults').style.display = 'none';
    }
}

// ═══════════════════════════════════════════════════════════════
// UTILITY HELPERS & CONSOLIDATED FUNCTIONS
// ═══════════════════════════════════════════════════════════════

/**
 * Escape HTML special characters
 */
function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

/**
 * CONSOLIDATED: Generic API call handler with loading/error/success states
 * Reduces code duplication across polishBullets, generateExperience, tailorResume, etc.
 * 
 * @param {string} endpoint - API endpoint path (e.g., '/polish-bullets')
 * @param {object} payload - Request body
 * @param {string} statusElementId - Element ID for status display (e.g., 'bulletStatus')
 * @param {function} onSuccess - Callback for successful response
 * @param {string} loadingMessage - Custom loading message
 */
async function makeApiCall(endpoint, payload, statusElementId, onSuccess, loadingMessage = 'Processing...') {
    try {
        // Show loading state
        if (statusElementId) {
            showStatus(statusElementId, loadingMessage, 'loading');
        }

        const response = await fetch(`${API_BASE}${endpoint}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });

        const data = await response.json();

        if (response.ok) {
            // Call success handler with response data
            if (onSuccess) {
                onSuccess(data);
            }
            
            // Show success message if statusElementId provided
            if (statusElementId) {
                showStatus(statusElementId, '✓ Success!', 'success');
                setTimeout(() => hideStatus(statusElementId), 3000);
            }
            
            return data;
        } else {
            throw new Error(data.error || `Server error: ${response.status}`);
        }
    } catch (error) {
        console.error(`API call failed for ${endpoint}:`, error);
        
        if (statusElementId) {
            showStatus(statusElementId, `Error: ${error.message}`, 'error');
        }
        
        throw error;
    }
}

/**
 * CONSOLIDATED: Generic resume list renderer
 * Eliminates duplicate code in renderResumeList, renderPolishResumeList, renderJobTailorResumeList
 * 
 * @param {string} containerId - Element ID of the container
 * @param {string} currentSelectedId - Currently selected item ID
 * @param {function} onSelectCallback - Callback when item is clicked
 * @param {string} classPrefix - CSS class prefix (e.g., 'resume', 'polish', 'tailor')
 * @param {string} emptyMessage - Custom empty state message
 */
function renderResumeListGeneric(containerId, currentSelectedId, onSelectCallback, classPrefix = 'resume', emptyMessage = 'No resumes yet') {
    const container = document.getElementById(containerId);
    if (!container) return;

    if (!resumesData || resumesData.length === 0) {
        const emptyStateMsg = emptyMessage.includes('No resumes') 
            ? emptyMessage + '\nUpload to get started'
            : emptyMessage;
        
        container.innerHTML = `
            <div class="${classPrefix}-empty-state">
                <div class="${classPrefix}-empty-icon">📋</div>
                <div>${emptyStateMsg.split('\n')[0]}</div>
                <div style="font-size: 11px; margin-top: 4px;">${emptyStateMsg.split('\n')[1] || ''}</div>
            </div>
        `;
        return;
    }

    container.innerHTML = resumesData.map(resume => `
        <div class="${classPrefix}-card ${currentSelectedId === resume.id ? 'active' : ''}" onclick="${onSelectCallback}(${resume.id})">
            <div class="${classPrefix}-card-title" style="${classPrefix === 'resume' ? 'margin-bottom: 4px;' : ''}">${resume.name}</div>
            ${classPrefix === 'resume' ? `<div class="${classPrefix}-card-meta"><span>${resume.uploadDate}</span><span>${resume.scores ? '✓ Graded' : (resume.content ? '•' : '○')}</span></div>` : ''}
        </div>
    `).join('');
}

/**
 * CONSOLIDATED: Generic loading placeholder
 * Used in multiple places instead of repeating HTML
 */
function getLoadingPlaceholder(message = 'Loading...', icon = '⏳', animation = true) {
    const animationStyle = animation ? ' animation: spin 2s linear infinite;' : '';
    return `
        <div style="display: flex; align-items: center; justify-content: center; height: 100%; flex-direction: column;">
            <div style="font-size: 32px; margin-bottom: 12px;${animationStyle}">${icon}</div>
            <div style="color: var(--text-muted);">${message}</div>
        </div>
    `;
}

/**
 * CONSOLIDATED: Generic error placeholder
 */
function getErrorPlaceholder(message = 'An error occurred', icon = '✕') {
    return `
        <div style="display: flex; align-items: center; justify-content: center; height: 100%; flex-direction: column; color: #e74c3c;">
            <div style="font-size: 36px; margin-bottom: 12px;">${icon}</div>
            <div style="text-align: center; max-width: 400px; white-space: pre-wrap;">${message}</div>
        </div>
    `;
}

function switchTab(tabId, button) {
    const container = button.closest('.tab-container').parentElement;
    container.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    container.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));

    document.getElementById(tabId).classList.add('active');
    button.classList.add('active');
}

function showStatus(elementId, message, type) {
    const el = document.getElementById(elementId);
    el.innerHTML = `<div class="status ${type}">${message}</div>`;
    el.style.display = 'block';
}

function hideStatus(elementId) {
    document.getElementById(elementId).style.display = 'none';
}

function showPreviewStatus(message, type) {
    const previewEl = document.getElementById('resumePreview');
    const statusClass = type === 'loading' ? '⏳' : type === 'success' ? '✓' : '✗';
    const color = type === 'success' ? 'var(--gold)' : type === 'error' ? '#FF6B6B' : 'var(--text-muted)';
    
    previewEl.innerHTML = `
        <div style="text-align: center; display: flex; flex-direction: column; gap: var(--spacing-lg); align-items: center;">
            <div style="font-size: 48px; font-weight: bold; color: ${color};">${statusClass}</div>
            <div style="font-size: 16px; color: var(--text-muted); max-width: 300px;">${message}</div>
        </div>
    `;
    
    document.getElementById('resumePreviewSection').style.display = 'block';
}


async function importResume() {
    const file = document.getElementById('resumeImportInput').files[0];
    if (!file) return;

    showPreviewStatus('Importing resume...', 'loading');
    document.getElementById('resumeScoresDisplay').style.display = 'none';

    const formData = new FormData();
    formData.append('file', file);

    try {
        // Step 1: Save file
        const response = await fetch(`${API_BASE}/parse-resume`, {
            method: 'POST',
            body: formData
        });

        const data = await response.json();

        if (response.ok) {
            currentFilename = data.filename;
            
            // Step 2: Load preview (displays directly)
            await loadResumePreview(currentFilename);
            
            // Step 3: Reload saved resumes list
            loadSavedResumes();
        } else {
            showPreviewStatus(`Error: ${data.error}`, 'error');
        }
    } catch (error) {
        showPreviewStatus(`Error: ${error.message}`, 'error');
    }
    
    // Reset file input
    document.getElementById('resumeImportInput').value = '';
}

async function loadResume(filename) {
    showPreviewStatus('Loading resume...', 'loading');
    document.getElementById('resumeScoresDisplay').style.display = 'none';

    try {
        currentFilename = filename;
        await loadResumePreview(filename);
    } catch (error) {
        showPreviewStatus(`Error: ${error.message}`, 'error');
    }
}

async function loadResumePreview(filename) {
    try {
        const response = await fetch(`${API_BASE}/preview-resume?filename=${encodeURIComponent(filename)}`);
        const data = await response.json();

        if (response.ok) {
            displayResumePreview(data.preview_type, data.preview_data);
        } else {
            throw new Error(data.error || 'Failed to load preview');
        }
    } catch (error) {
        console.error('Error loading preview:', error);
        throw error;
    }
}

function displayResumePreview(type, data) {
    const previewEl = document.getElementById('resumePreview');
    
    if (type === 'image') {
        // Display PDF image - let container handle scrolling
        previewEl.innerHTML = `<img src="${data}" style="max-width: 100%; height: auto; border-radius: var(--border-radius); box-shadow: 0 2px 8px rgba(0,0,0,0.2);" />`;
    } else {
        // Display text - let container handle scrolling
        previewEl.innerHTML = `<pre style="background: var(--bg-secondary); padding: var(--spacing-md); border-radius: var(--border-radius); font-size: 12px; white-space: pre-wrap; word-wrap: break-word;">${data}</pre>`;
    }
    
    document.getElementById('resumePreviewSection').style.display = 'block';
    
    // Hide scores until graded
    document.getElementById('resumeScoresDisplay').style.display = 'none';
}

// ═══════════════════════════════════════════════════════════════
// API CALLS - EXISTING & UPDATED
// ═══════════════════════════════════════════════════════════════

async function gradeResume() {
    if (!currentFilename) {
        showPreviewStatus('Please load a resume first', 'error');
        return;
    }

    showPreviewStatus('Grading resume...', 'loading');

    try {
        const response = await fetch(`${API_BASE}/grade-resume`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ filename: currentFilename })
        });

        const data = await response.json();

        if (response.ok) {
            const scores = data.scores;
            document.getElementById('scoreOverall').textContent = scores.overall || '-';
            document.getElementById('scoreATS').textContent = scores.ats_score || '-';
            document.getElementById('scoreSections').textContent = scores.sections_score || '-';
            document.getElementById('scoreBullets').textContent = scores.bullets_score || '-';

            document.getElementById('resumeScoresDisplay').style.display = 'block';
        } else {
            showPreviewStatus(`Error: ${data.error}`, 'error');
        }
    } catch (error) {
        showPreviewStatus(`Error: ${error.message}`, 'error');
    }
}

