 */
async function initPolishResume() {
    await loadResumesFromFolder();  // Load from actual folder, not localStorage
    renderPolishResumeList();
}

/**
 * Render the resume list for Polish Resume
 * CONSOLIDATED: Uses generic list renderer
 */
function renderPolishResumeList() {
    renderResumeListGeneric('polishResumeList', currentPolishResumeId, 'selectPolishResume', 'polish-card', 'No resumes yet\nUpload resumes in the Resumes section');
}

/**
 * Select a resume for polishing
 */
function selectPolishResume(resumeId) {
    currentPolishResumeId = resumeId;
    const resume = resumesData.find(r => r.id === resumeId);

    if (!resume) return;

    // Update active state
    renderPolishResumeList();

    // Load and display original resume
    loadResumeContent(resumeId)
        .then(() => {
            const resume = resumesData.find(r => r.id === resumeId);
            const previewContent = document.getElementById('polishOriginalPreview');
            previewContent.innerHTML = `<div class="resume-text">${resume.content}</div>`;
            
            // Show Polish button
            document.getElementById('polishBtn').style.display = 'block';
            
            // Reset polished preview
            resetPolishedPreview();
        })
        .catch(error => {
            document.getElementById('polishOriginalPreview').innerHTML = `
                <div class="polish-placeholder">
                    <div style="font-size: 36px; margin-bottom: 12px; color: #e74c3c;">✕</div>
                    <div style="color: #e74c3c;">Error: ${error.message}</div>
                </div>
            `;
        });
}

/**
 * Reset the polished preview
 */
function resetPolishedPreview() {
    const polishedContent = document.getElementById('polishPolishedPreview');
    polishedContent.innerHTML = `
        <div class="polish-placeholder">
            <div class="polish-placeholder-icon">✨</div>
            <div>Polish Resume button to see results</div>
        </div>
    `;
}

/**
 * Polish the selected resume
 */
async function polishResume() {
    if (!currentPolishResumeId) {
        alert('Please select a resume first');
        return;
    }

    const resume = resumesData.find(r => r.id === currentPolishResumeId);
    if (!resume || !resume.content) {
        alert('Resume content not available');
        return;
    }

    const polishedContent = document.getElementById('polishPolishedPreview');
    polishedContent.innerHTML = `
        <div class="polish-placeholder">
            <div style="font-size: 24px; margin-bottom: 12px; animation: spin 2s linear infinite;">⏳</div>
            <div>Polishing resume...</div>
        </div>
    `;

    try {
        const response = await fetch(`${API_BASE}/polish-resume`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ resume_content: resume.content })
        });

        const data = await response.json();

        if (response.ok) {
            // Display polished resume and changes
            const polishedText = data.polished_resume || data.resume_polished || '';
            const changes = data.changes || data.improvements || 'Resume has been enhanced with professional language and optimized phrasing.';
            
            polishedContent.innerHTML = `
                <div class="resume-text">${polishedText}</div>
                <div class="changes-section">
                    <div class="changes-title">📝 Changes Made:</div>
                    <div>${typeof changes === 'string' ? changes : changes.map((c, i) => `<div class="change-item">• ${c}</div>`).join('')}</div>
                </div>
            `;
        } else {
            polishedContent.innerHTML = `
                <div class="polish-placeholder">
                    <div style="font-size: 36px; margin-bottom: 12px; color: #e74c3c;">✕</div>
                    <div style="color: #e74c3c;">Error: ${data.error || 'Failed to polish resume'}</div>
                </div>
            `;
        }
    } catch (error) {
        polishedContent.innerHTML = `
            <div class="polish-placeholder">
                <div style="font-size: 36px; margin-bottom: 12px; color: #e74c3c;">✕</div>
                <div style="color: #e74c3c;">Error: ${error.message}</div>
            </div>
        `;
    }
}

